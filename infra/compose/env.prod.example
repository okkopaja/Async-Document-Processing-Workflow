NODE_ENV=production

NEXT_PUBLIC_API_BASE_URL=https://project.hiderview.app
NEXT_PUBLIC_WS_BASE_URL=wss://project.hiderview.app

APP_ENV=production
API_PORT=8000
DATABASE_URL=postgresql+psycopg://app:change_me@postgres:5432/docflow
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
UPLOAD_DIR=/workspace/data/uploads
MAX_UPLOAD_MB=25
ALLOWED_EXTENSIONS=txt,md,pdf,docx,csv
LOG_LEVEL=INFO
CORS_ORIGINS=https://project.hiderview.app

POSTGRES_DB=docflow
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me